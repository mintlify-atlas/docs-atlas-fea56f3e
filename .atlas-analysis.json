  "keyFeatures": [
    "Open-source Linux kernel modules for NVIDIA Turing and later GPUs",
    "Four kernel modules: nvidia.ko (core), nvidia-drm.ko (DRM/KMS), nvidia-modeset.ko (display), nvidia-uvm.ko (unified memory)",
    "Split architecture: OS-agnostic component and kernel interface layer",
    "GSP firmware-based GPU management",
    "DKMS support for automatic kernel module rebuilding",
    "Cross-compilation support for x86_64 and aarch64",
    "Nouveau device driver integration for firmware extraction",
    "Peer memory (GPUDirect) support via nvidia-peermem module",
    "Unified Virtual Memory (UVM) for CPU-GPU memory coherence"
  ],
  "publicApiSurface": [
    "make modules (build kernel modules)",
    "make modules_install (install kernel modules)",
    "NV_VERBOSE=1 (verbose build output)",
    "DEBUG=1 (debug build with logging)",
    "TARGET_ARCH=aarch64|x86_64 (cross-compilation target)",
    "nvidia-uvm ioctl API (uvm_ioctl.h)",
    "nvidia-modeset NVKMS kernel API (nvkms-kapi.h)",
    "nv_uvm_interface.h (UVM-RM interface)",
    "nv-p2p.h (GPUDirect peer-to-peer API)",
    "nvidia-drm DRM/KMS interface",
    "extract-firmware-nouveau.py (Nouveau firmware extraction)"
  ]
}
